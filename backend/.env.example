# Account-scoped key from https://app.ara.so
ARA_API_KEY=ara_api_key_...
# Optional override (defaults to https://api.ara.so)
ARA_API_BASE_URL=https://api.ara.so

# Ara Agent used for per-platform tailoring (plain chat, no connectors needed).
ARA_AGENT_ID=agent_...
# Agent-scoped key minted via POST /agents/{id}/keys (starts with ak_live_).
ARA_AGENT_KEY=ak_live_...

# Ara App (deployed Automation) used for connector-backed posting.
# Get these from `ara deploy poster.py` — the command prints an app_id and a runtime key.
# See backend/README.md for the exact flow.
ARA_APP_ID=
ARA_APP_KEY=

# Where the JSON store lives. Defaults to ./data/store.json relative to backend/.
ARA_STORE_PATH=./data/store.json
