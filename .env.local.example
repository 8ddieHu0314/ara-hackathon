# --- Ara.so ---
# Account-scoped API key from https://app.ara.so. Used for agent/app mgmt endpoints.
ARA_API_KEY=ara_api_key_...
# Base URL for Ara Cloud API. Defaults to https://api.ara.so if unset.
ARA_API_BASE_URL=https://api.ara.so
# Ara Agent used for BOTH per-platform tailoring and connector-backed posting.
#
# Create it once:
#   curl -sS -X POST $ARA_API_BASE_URL/agents \
#     -H "Authorization: Bearer $ARA_API_KEY" -H "Content-Type: application/json" \
#     -d '{"name":"signal","model":"anthropic/claude-sonnet-4.6","temperature":0.7}'
#
# Then enable the LinkedIn + Reddit connectors on that agent in app.ara.so
# so publishing calls can reach those toolkits.
ARA_AGENT_ID=agent_...
# Agent-scoped runtime key. Used as Bearer on POST /v1/agents/{id}/chat.
#
# Create once (shown only once — store it):
#   curl -sS -X POST $ARA_API_BASE_URL/agents/$ARA_AGENT_ID/keys \
#     -H "Authorization: Bearer $ARA_API_KEY" -H "Content-Type: application/json" \
#     -d '{"name":"signal-local","requests_per_minute":60}'
#
# If either ARA_AGENT_ID or ARA_AGENT_KEY is empty, Signal falls back to mock mode
# for tailoring AND posting so the demo still runs end-to-end.
ARA_AGENT_KEY=ak_live_...

# Posts are persisted to ./data/store.json on disk — no database required.
