# --- Ara.so ---
# Get from https://app.ara.so (account API key).
ARA_API_KEY=ara_...
# Base URL for Ara Cloud API. Defaults to https://api.ara.so if unset.
ARA_API_BASE_URL=https://api.ara.so
# Model to use via Ara's LLM gateway for per-platform tailoring.
ARA_MODEL=anthropic/claude-sonnet-4.6
# Ara Agent ID used to post to connected LinkedIn / Reddit toolkits.
# Create an Agent in app.ara.so, enable LinkedIn + Reddit connectors, paste the ID here.
# If left empty, posting falls back to mock mode for every platform.
ARA_AGENT_ID=

# --- Supabase ---
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service role key (server-side only). Used by API routes to bypass RLS for the demo.
SUPABASE_SERVICE_ROLE_KEY=ey...
